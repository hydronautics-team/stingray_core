{
    "configurations": [
        {
            "browse": {
                "limitSymbolsToIncludedHeaders": true,
                "path": [
                    "${workspaceFolder}/src/**",
                    "${workspaceFolder}/install/**/include/**",
                    "/opt/ros/humble/include/**",
                    "/usr/include/**"
                ]
            },
            "compileCommands": "${workspaceFolder}/compile_commands.json",
            "includePath": [
                "${workspaceFolder}/src/**",
                "${workspaceFolder}/install/**/include/**",
                "/opt/ros/humble/include/**",
                "/usr/include/**",
                "${workspaceFolder}/src/stingray_core_communication/serial/include",
                "${workspaceFolder}/src/stingray_core_communication/serial_driver/include",
                "${workspaceFolder}/src/stingray_core_communication/io_context/include"
            ],
            "name": "ROS Humble",
            "intelliSenseMode": "linux-clang-x64",
            "compilerPath": "/usr/bin/clang++",
            "cStandard": "gnu11",
            "cppStandard": "c++20",
            "mergeConfigurations": false
        }
    ],
    "version": 4
}
